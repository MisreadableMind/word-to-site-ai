# InstaWP Configuration
# You can set these here OR enter them via the web interface
INSTA_WP_API_KEY=your_instawp_api_key_here
TEMPLATE_SLUG=wordtosite_template
SNAPSHOT_SLUG=waas-snapshot

# Server Configuration
PORT=3000

# Admin API key for /api/health and /api/config (leave empty for open access)
ADMIN_API_KEY=

# ===========================================
# AI Proxy (centralized AI access for deployed sites)
# ===========================================

# Enable the proxy router (default: true)
ENABLE_AI_PROXY=true

# Shared secret for /api/proxy/admin/* endpoints. Without it those routes return 404.
PROXY_ADMIN_SECRET=

# Public origin of this server (no trailing /api/proxy). Falls back to the request's
PROXY_PUBLIC_BASE_URL=

# ===========================================
# Domain Workflow Configuration (Optional)
# Required only if using domain registration/mapping features
# ===========================================

# Namecheap Configuration (for domain registration)
# Get API access at: https://www.namecheap.com/support/api/intro/
NAMECHEAP_API_KEY=your_namecheap_api_key
NAMECHEAP_USERNAME=your_namecheap_username
NAMECHEAP_CLIENT_IP=your_whitelisted_ip

# NAMECHEAP_SANDBOX=true points at api.sandbox.namecheap.com — required in dev
# unless ALLOW_REAL_NAMECHEAP_IN_DEV=true is also set. registerDomain() throws
# at runtime if NODE_ENV=development and neither flag is set.
NAMECHEAP_SANDBOX=true
# ALLOW_REAL_NAMECHEAP_IN_DEV=false

# Cloudflare Configuration (for DNS management)
# Get API key at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_KEY=your_cloudflare_global_api_key
CLOUDFLARE_EMAIL=your_cloudflare_email
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Domain Registration Contact Information
# Required when registering new domains via Namecheap
DOMAIN_CONTACT_FIRST_NAME=John
DOMAIN_CONTACT_LAST_NAME=Doe
DOMAIN_CONTACT_ADDRESS=123 Main Street
DOMAIN_CONTACT_CITY=New York
DOMAIN_CONTACT_STATE=NY
DOMAIN_CONTACT_POSTAL_CODE=10001
DOMAIN_CONTACT_COUNTRY=US
DOMAIN_CONTACT_PHONE=+1.2125551234
DOMAIN_CONTACT_EMAIL=contact@example.com

# ===========================================
# Base Site Configuration (TRXWaaSWizard plugin)
# The base WordPress site that provides skins and languages
# ===========================================
BASE_SITE_URL=https://waas-site.at.wordtosite.ai
BASE_SITE_USERNAME=your_wp_username
BASE_SITE_APP_PASSWORD=your_wp_app_password

# ===========================================
# AI & Content Generation (Optional)
# Required for onboarding wizard and AI features
# ===========================================

# OpenAI Configuration (GPT-4o for content generation, Whisper for voice)
# Get API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Google Gemini Configuration (Visual analysis with 1M+ token context)
# Get API key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Firecrawl Configuration (Website scraping for Flow A)
# Get API key at: https://firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key

# ===========================================
# User Authentication
# ===========================================

# Enable user auth (register/login/dashboard). Default: true
ENABLE_USER_AUTH=true

# Session lifetime in milliseconds (default: 7 days)
# SESSION_MAX_AGE=604800000

# bcrypt hashing rounds (default: 12)
# BCRYPT_ROUNDS=12

# ===========================================
# Stripe Billing (Optional)
# Setting STRIPE_SECRET_KEY is the on-switch — billing routes and entitlement
# enforcement activate as soon as it's present. Get keys at:
# https://dashboard.stripe.com/apikeys
#
# One-time Stripe setup: after STRIPE_SECRET_KEY is set, run
#   npm run stripe:setup -- --dry-run     # preview, no writes
#   npm run stripe:setup                   # create Products + Prices with lookup_keys
# The script creates wts_starter / wts_pro / wts_business Prices from
# src/billing/entitlements.js. Idempotent — safe to re-run.
#
# Redirect URLs (success / cancel / portal return) are derived from the request
# origin — Express trust-proxy is enabled, so X-Forwarded-Host / X-Forwarded-Proto
# behind a reverse proxy will produce the correct public URL.
# ===========================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ===========================================
# Image Bank (Optional)
# Credentials for plugin-side stock image generation
# ===========================================
IMAGE_BANK_LOGIN=
IMAGE_BANK_PASSWORD=
IMAGE_BANK_SCORE_THRESHOLD=0.85

# ===========================================
# Feature Flags
# ===========================================

# Enable voice interview flow (requires OpenAI)
ENABLE_VOICE_FLOW=true

# Enable Light Editor (chat-based editing)
ENABLE_LIGHT_EDITOR=true

# Enable AI content generation (requires OpenAI)
ENABLE_AI_CONTENT=true
