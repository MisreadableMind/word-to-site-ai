{
  "name": "wordtosite",
  "version": "3.0.0",
  "description": "WordToSite - Website as a Service with AI-powered onboarding wizard",
  "main": "src/server.ts",
  "exports": {
    ".": "./src/server.js"
  },
  "type": "module",
  "scripts": {
    "dev": "NODE_EXTRA_CA_CERTS=./certs/letsencrypt-gen-y.pem vite dev --port 3000",
    "build": "NODE_OPTIONS=\"--import tsx\" vite build",
    "start": "NODE_EXTRA_CA_CERTS=./certs/letsencrypt-gen-y.pem node --import tsx .output/server/index.mjs",
    "db:migration": "bash scripts/create-db-migration.sh",
    "typecheck": "tsc",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "stripe:setup": "node --import tsx scripts/stripe-setup.js"
  },
  "keywords": [
    "instawp",
    "wordpress",
    "site-creator",
    "automation",
    "waas",
    "ai-content",
    "onboarding-wizard"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "1.170.11",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.19",
    "agentkeepalive": "^4.6.0",
    "axios": "^1.6.0",
    "axios-retry": "^4.5.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "colord": "^2.9.3",
    "dompurify": "^3.4.7",
    "dotenv": "^16.3.1",
    "drizzle-orm": "0.45.2",
    "express": "^4.18.2",
    "https-proxy-agent": "^9.0.0",
    "lodash-es": "^4.18.1",
    "luxon": "^3.7.2",
    "marked": "^15.0.12",
    "motion": "^12.40.0",
    "multer": "^2.0.2",
    "normalize-url": "^9.0.1",
    "openai": "^6.25.0",
    "p-retry": "^8.0.0",
    "p-wait-for": "^6.0.0",
    "pg": "^8.13.0",
    "randomstring": "^1.3.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "stripe": "^17.7.0",
    "tldts": "^7.0.30",
    "tsx": "^4.20.6",
    "validator": "^13.15.35",
    "ws": "^8.21.0",
    "xml2js": "^0.6.2",
    "zod": "^4.3.6",
    "zod-empty": "^2.1.0"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "1.168.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.19.19",
    "@types/randomstring": "^1.3.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "^9.2.1",
    "nitro": "npm:nitro-nightly@^3.0.1-20260603-085201-f0cb358c",
    "nodemon": "^3.1.11",
    "typescript": "^5.9.3",
    "vite": "8.0.16",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
